CXMIND_DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/cxmind

# Security
CXMIND_JWT_SECRET=CHANGE_ME_IN_PROD
CXMIND_AUTH_ENABLED=true

# CORS (comma-separated)
CXMIND_CORS_ORIGINS=http://localhost:5173,http://localhost

# Rate limiting
CXMIND_RATE_LIMIT_ENABLED=true
CXMIND_RATE_LIMIT_PER_MINUTE=120
CXMIND_RATE_LIMIT_AUTH_PER_MINUTE=20

# NLP (offline-safe by default)
CXMIND_ALLOW_MODEL_DOWNLOADS=false
